---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quiz Results">
  <div class="card w-full max-w-md bg-base-100 shadow-xl border border-base-300">
    <div class="card-body items-center text-center py-12">
      <h2 class="card-title text-4xl font-black mb-4 text-primary">Finish!</h2>
      
      <div class="relative w-48 h-48 flex items-center justify-center my-6">
        <svg class="w-full h-full transform -rotate-90">
          <circle
            cx="96"
            cy="96"
            r="80"
            stroke="currentColor"
            stroke-width="12"
            fill="transparent"
            class="text-base-200"
          />
          <circle
            id="result-circle"
            cx="96"
            cy="96"
            r="80"
            stroke="currentColor"
            stroke-width="12"
            fill="transparent"
            stroke-dasharray="502.4"
            stroke-dashoffset="502.4"
            class="text-primary transition-all duration-1000 ease-out"
          />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <span id="final-score" class="text-5xl font-bold">0</span>
          <span class="text-base-content/60 font-medium">out of 10</span>
        </div>
      </div>

      <p id="result-message" class="text-lg font-medium mb-8">Loading results...</p>

      <div class="flex flex-col gap-3 w-full">
        <button id="share-twitter" class="btn btn-outline gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
          </svg>
          Share on X
        </button>
        <a href="/" class="btn btn-primary mt-4">Play Again</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const score = parseInt(localStorage.getItem('quiz-score') || '0');
  const finalScoreEl = document.getElementById('final-score');
  const messageEl = document.getElementById('result-message');
  const circleEl = document.getElementById('result-circle');
  const shareBtn = document.getElementById('share-twitter');

  finalScoreEl!.innerText = score.toString();

  // Animation for the circle
  const percentage = (score / 10);
  const offset = 502.4 - (502.4 * percentage);
  
  setTimeout(() => {
    circleEl!.style.strokeDashoffset = offset.toString();
  }, 100);

  // Messages based on score
  if (score === 10) messageEl!.innerText = "Perfect! You're a true Master! 🏆";
  else if (score >= 8) messageEl!.innerText = "Amazing job! You really know your stuff! 🌟";
  else if (score >= 5) messageEl!.innerText = "Good effort! Keep learning! 👍";
  else messageEl!.innerText = "Better luck next time! Practice makes perfect! 💪";

  // Sharing logic
  shareBtn?.addEventListener('click', () => {
    const text = `I just scored ${score}/10 on the Quiz Master! Can you beat me? 🎮`;
    const url = window.location.origin;
    window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`, '_blank');
  });
</script>
