---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quiz Master - Welcome">
	<div class="card w-full max-w-md bg-base-100 shadow-xl border border-base-300">
		<figure class="px-10 pt-10">
			<div class="w-24 h-24 bg-primary rounded-full flex items-center justify-center text-primary-content text-4xl font-bold shadow-lg">
				?
			</div>
		</figure>
		<div class="card-body items-center text-center py-8">
			<h2 class="card-title text-3xl font-black mb-2">Quiz Master!</h2>
			<p class="text-base-content/70 text-lg">Test your knowledge with 10 exciting questions. Can you get a perfect score?</p>
			
			<div class="stats shadow bg-base-200 w-full my-6">
				<div class="stat place-items-center p-4">
					<div class="stat-title text-xs uppercase font-bold">Questions</div>
					<div class="stat-value text-2xl">10</div>
				</div>
				<div class="stat place-items-center p-4">
					<div class="stat-title text-xs uppercase font-bold">Difficulty</div>
					<div class="stat-value text-2xl text-secondary">Medium</div>
				</div>
			</div>

			<div class="card-actions w-full">
				<a href="/quiz" class="btn btn-primary btn-lg w-full font-bold shadow-lg">Start Quiz</a>
			</div>
		</div>
	</div>
</Layout>
