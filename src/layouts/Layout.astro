---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-base-200 min-h-screen flex flex-col items-center p-4 pt-8 md:pt-16">
		<main class="w-full max-w-2xl flex flex-col items-center">
			<slot />
		</main>

		<footer class="mt-auto py-8 opacity-50 text-sm text-center">
			<div class="mb-4">[Google Ads Placeholder]</div>
			<p>&copy; 2026 Quiz Game. All rights reserved.</p>
		</footer>
	</body>
</html>
